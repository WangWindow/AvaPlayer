<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaPlayer.ViewModels"
             x:Name="Root"
             x:Class="AvaPlayer.Views.LyricsView"
             x:DataType="vm:LyricsViewModel">
  <Grid Margin="36,40,36,40">
    <TextBlock Text="加载歌词中..."
               Foreground="#80FFFFFF"
               FontSize="14"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsVisible="{Binding IsLoading}" />

    <TextBlock Text="暂无歌词"
               Foreground="#66FFFFFF"
               FontSize="14"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsVisible="{Binding ShowEmptyState}" />

    <ScrollViewer x:Name="LyricsScroller"
                  IsVisible="{Binding HasLyrics}"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Hidden"
                  Padding="0,160,0,160">
      <ItemsControl x:Name="LyricsItems"
                    ItemsSource="{Binding Lines}"
                    Width="{Binding #LyricsScroller.Viewport.Width}"
                    MaxWidth="560"
                    HorizontalAlignment="Center">
        <ItemsControl.Styles>
          <Style Selector="ContentPresenter">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
          </Style>
        </ItemsControl.Styles>
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:LyricLineViewModel">
            <Button Classes="lyric-line-button"
                    Classes.active="{Binding IsCurrent}"
                    Classes.near="{Binding IsNearCurrent}"
                    Command="{Binding #Root((vm:LyricsViewModel)DataContext).SeekToLineCommand}"
                    CommandParameter="{Binding}"
                    HorizontalAlignment="Stretch">
              <TextBlock Text="{Binding Text}"
                         FontSize="{Binding DisplayFontSize}"
                         Opacity="{Binding DisplayOpacity}"
                         Classes="lyric-line"
                         Classes.near="{Binding IsNearCurrent}"
                         Classes.active="{Binding IsCurrent}" />
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
