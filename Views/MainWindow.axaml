<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaPlayer.ViewModels"
        xmlns:views="using:AvaPlayer.Views"
        xmlns:fi="using:FluentIcons.Avalonia"
        x:Class="AvaPlayer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Resources/logo.ico"
        Width="1020"
        Height="660"
        MinWidth="820"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Title="AvaPlayer"
        Background="{Binding PlayerBar.BackgroundBrush}">
  <Panel>
    <Grid ColumnDefinitions="46*,54*">
      <Border Grid.Column="0"
              Background="#08000000">
        <views:PlayerBarView DataContext="{Binding PlayerBar}" />
      </Border>

      <Border Grid.Column="1"
              Background="#04000000">
        <views:LyricsView DataContext="{Binding PlayerBar.Lyrics}" />
      </Border>
    </Grid>

    <Button Classes="ghost"
            Width="40"
            Height="40"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="16,16,0,0"
            Command="{Binding TogglePlaylistCommand}">
      <fi:FluentIcon Icon="AppsList" FontSize="18" />
    </Button>

    <Grid Classes="playlist-drawer-host"
          Classes.open="{Binding IsPlaylistVisible}">
      <Border Classes="playlist-drawer-scrim"
              Classes.open="{Binding IsPlaylistVisible}" />

      <Grid ColumnDefinitions="380,*">
        <Border Grid.Column="0"
                Classes="playlist-drawer-panel"
                Classes.open="{Binding IsPlaylistVisible}">
          <Grid RowDefinitions="Auto,*">
            <DockPanel Margin="16,16,16,12">
              <TextBlock Text="播放列表"
                         Foreground="White"
                         FontSize="18"
                         FontWeight="SemiBold"
                         VerticalAlignment="Center" />

              <Button DockPanel.Dock="Right"
                      Classes="ghost"
                      Width="36"
                      Height="36"
                      Command="{Binding ClosePlaylistCommand}">
                <fi:FluentIcon Icon="Dismiss" FontSize="16" />
              </Button>
            </DockPanel>

            <views:PlaylistView Grid.Row="1"
                                DataContext="{Binding Playlist}" />
          </Grid>
        </Border>

        <Border x:Name="OverlayDismissArea"
                Grid.Column="1"
                Background="Transparent"
                PointerPressed="OnOverlayDismissPointerPressed" />
      </Grid>
    </Grid>
  </Panel>
</Window>
